<a href="https://wa.me/919999999999?text=Hi!%20Interested%20in%20nail%20art%20💅" class="swa" target="_blank"><svg viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.11.549 4.09 1.505 5.818L.057 23.882a.5.5 0 0 0 .61.64l6.213-1.63A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.9 0-3.68-.528-5.193-1.44l-.37-.222-3.84 1.008 1.027-3.745-.242-.386A9.943 9.943 0 0 1 2 12c0-5.514 4.486-10 10-10s10 4.486 10 10-4.486 10-10 10z"/></svg></a>

<footer><img src="images/logo.jpg" alt="Srini's Nailora"><p>Made with <span>♥</span> · Srini's Nailora · Thiruverkadu, Chennai · © 2025</p></footer>

<!-- POPUP -->
<div class="pov" id="pov" onclick="if(event.target===this)clP()"><div class="pop"><div class="pcl" onclick="clP()">✕</div><div id="pc"></div></div></div>

<script>
window.addEventListener('load',()=>setTimeout(()=>document.getElementById('loader').classList.add('gone'),2500));

const cur=document.getElementById('cur'),crg=document.getElementById('crg');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cur.style.transform=`translate(${mx-4}px,${my-4}px)`});
(function a(){rx+=(mx-rx)*0.1;ry+=(my-ry)*0.1;crg.style.transform=`translate(${rx-18}px,${ry-18}px)`;requestAnimationFrame(a)})();
document.querySelectorAll('a,button,.gl,.sw,.gi,.fq').forEach(el=>{el.addEventListener('mouseenter',()=>{crg.style.width='50px';crg.style.height='50px';crg.style.opacity='0.4'});el.addEventListener('mouseleave',()=>{crg.style.width='36px';crg.style.height='36px';crg.style.opacity='1'})});

const pc=document.getElementById('ptcls');for(let i=0;i<30;i++){const p=document.createElement('div');p.className='ptcl';p.style.left=Math.random()*100+'%';p.style.animationDelay=Math.random()*8+'s';p.style.animationDuration=(6+Math.random()*6)+'s';pc.appendChild(p)}

const obs=new IntersectionObserver(en=>{en.forEach(e=>{if(e.isIntersecting)e.target.classList.add('on')})},{threshold:0.1});
document.querySelectorAll('.rv').forEach(el=>obs.observe(el));

window.addEventListener('scroll',()=>{const s=window.scrollY;document.querySelectorAll('[data-speed]').forEach(el=>{const sp=parseFloat(el.dataset.speed);el.style.transform=`translateY(${s*sp*-0.1}px)`})});

const ed=new Date();ed.setDate(ed.getDate()+2);ed.setHours(ed.getHours()+18);
function uT(){const d=ed-new Date();if(d<=0)return;document.getElementById('days').textContent=String(Math.floor(d/864e5)).padStart(2,'0');document.getElementById('hrs').textContent=String(Math.floor((d%864e5)/36e5)).padStart(2,'0');document.getElementById('mins').textContent=String(Math.floor((d%36e5)/6e4)).padStart(2,'0');document.getElementById('secs').textContent=String(Math.floor((d%6e4)/1e3)).padStart(2,'0')}
uT();setInterval(uT,1000);

const cv=document.getElementById('hc'),cx=cv.getContext('2d');
const hi=new Image();let il=false,cc='#FF6B9D';
const NL=[{cx:82,cy:340,rx:18,ry:14,rot:-20},{cx:130,cy:175,rx:17,ry:22,rot:-5},{cx:182,cy:142,rx:17,ry:24,rot:0},{cx:232,cy:160,rx:16,ry:22,rot:5},{cx:272,cy:210,rx:13,ry:18,rot:12}];
hi.onload=function(){il=true;dH(cc)};hi.src='images/hand.jpg';
function h2r(h){return{r:parseInt(h.slice(1,3),16),g:parseInt(h.slice(3,5),16),b:parseInt(h.slice(5,7),16)}}
function dH(c){cx.clearRect(0,0,cv.width,cv.height);cx.drawImage(hi,0,0,cv.width,cv.height);NL.forEach(n=>{cx.save();cx.translate(n.cx,n.cy);cx.rotate(n.rot*Math.PI/180);cx.beginPath();cx.ellipse(0,0,n.rx,n.ry,0,0,Math.PI*2);cx.clip();const r=h2r(c);cx.fillStyle=`rgba(${r.r},${r.g},${r.b},0.82)`;cx.fillRect(-n.rx-2,-n.ry-2,n.rx*2+4,n.ry*2+4);cx.beginPath();cx.ellipse(-n.rx*0.2,-n.ry*0.3,n.rx*0.4,n.ry*0.28,-0.4,0,Math.PI*2);cx.fillStyle='rgba(255,255,255,0.25)';cx.fill();cx.restore()})}
document.querySelectorAll('.sw').forEach(s=>{s.addEventListener('click',()=>{document.querySelectorAll('.sw').forEach(x=>x.classList.remove('on'));s.classList.add('on');cc=s.dataset.c;document.getElementById('clabel').textContent='✦ '+s.dataset.n;if(il)dH(cc)})});
const ac=[{c:'#FF6B9D',n:'Hot Pink'},{c:'#E53E3E',n:'Classic Red'},{c:'#9F7AEA',n:'Lavender'},{c:'#ECC94B',n:'Gold Dust'},{c:'#702459',n:'Wine'},{c:'#D4956A',n:'Rose Gold'}];
let ai=0,at=setInterval(()=>{ai=(ai+1)%ac.length;cc=ac[ai].c;document.getElementById('clabel').textContent='✦ '+ac[ai].n;document.querySelectorAll('.sw').forEach(x=>x.classList.remove('on'));const m=[...document.querySelectorAll('.sw')].find(s=>s.dataset.c===ac[ai].c);if(m)m.classList.add('on');if(il)dH(cc)},3000);
document.getElementById('pal').addEventListener('click',()=>clearInterval(at));

function tFaq(el){el.classList.toggle('open');el.nextElementSibling.classList.toggle('open')}

const pd={gel:{i:'💎',t:'Gel Extensions',d:'Lightweight, natural-looking, durable. Applied using soft gel cured under UV/LED.',f:['Lightweight & comfortable','Natural finish','Lasts 2-3 weeks','Any shape & length','UV/LED cured','100% customizable']},acr:{i:'💅',t:'Acrylic Extensions',d:'Strongest extension — perfect for bold, lasting nails.',f:['Strongest type','Long-lasting','Bold looks','Easy to maintain','Great for nail biters','All shapes']},pol:{i:'🔮',t:'Polygel Extensions',d:'Best of both — lighter than acrylic, stronger than gel. Odorless.',f:['Flexible & lightweight','Odorless','Easy to shape','Natural feel','Great for beginners','No monomer smell']},gx:{i:'🩷',t:'Soft Gel / Gel-X',d:'Pre-shaped tips for perfect fit. Quick, beautiful, safe.',f:['Pre-shaped tips','45-min application','Natural fit','Safe for nails','Easy removal','Perfect for first-timers']},po:{i:'🎀',t:'Press-On Nails',d:'Instant glam! Custom reusable sets to take home.',f:['Instant application','Reusable','Custom designed','No damage','Perfect for events','Take home!']},art:{i:'🎨',t:'Custom Nail Art',d:'Ombre, chrome, floral, marble, 3D — any design!',f:['Ombre & gradient','Chrome & mirror','3D nail art','Rhinestones & gems','Gold foil','Send any reference!']}};
function openP(k){const d=pd[k];if(!d)return;document.getElementById('pc').innerHTML=`<div style="font-size:2.5rem;margin-bottom:0.5rem">${d.i}</div><h3>${d.t}</h3><p class="pd">${d.d}</p><ul class="pf">${d.f.map(f=>`<li>${f}</li>`).join('')}</ul><p style="color:var(--gold);font-weight:600;font-size:1.1rem;margin:1rem 0">Starting ₹349</p><p style="color:var(--muted);font-size:0.8rem;margin-bottom:1.5rem">✅ Any shape · Any length · Any design · Home visits</p><a href="https://wa.me/919999999999?text=Hi!%20Interested%20in%20${encodeURIComponent(d.t)}%20💅" class="bg" style="width:100%;text-align:center" target="_blank">📲 Book on WhatsApp</a>`;document.getElementById('pov').classList.add('show');document.body.style.overflow='hidden'}
function clP(){document.getElementById('pov').classList.remove('show');document.body.style.overflow=''}
</script>
</body>
</html>
