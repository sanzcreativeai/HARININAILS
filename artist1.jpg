<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Srini's Nailora — NAIL ARTISTRY · Thiruverkadu, Chennai</title>
<meta name="description" content="Premium nail art & extensions by Srini — starting ₹349. Thiruverkadu, Chennai.">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,800;1,400;1,700&family=DM+Sans:wght@300;400;500;600&family=Great+Vibes&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{--bg:#1A0A14;--bg2:#2D1520;--rose:#D4956A;--gold:#E8C99A;--pink:#F4B8C8;--text:#FFF0F5;--muted:#C4A4B0;--deep:#8B3A4A;--burg:#3D0F20}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);overflow-x:hidden}

/* LOADER */
#loader{position:fixed;inset:0;background:var(--burg);z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;transition:opacity 1s,visibility 1s}
#loader.gone{opacity:0;visibility:hidden;pointer-events:none}
#loader img{width:180px;animation:lp 1.8s ease-in-out infinite}
.lbar{width:180px;height:2px;background:rgba(255,255,255,0.1);margin-top:24px;border-radius:2px;overflow:hidden}
.lfill{height:100%;background:linear-gradient(90deg,var(--rose),var(--gold));animation:lf 2.2s ease forwards}
@keyframes lp{0%,100%{opacity:0.5;transform:scale(0.98)}50%{opacity:1;transform:scale(1)}}
@keyframes lf{0%{width:0}100%{width:100%}}

/* CURSOR */
.cur{width:8px;height:8px;background:var(--rose);border-radius:50%;position:fixed;pointer-events:none;z-index:9998}
.crg{width:36px;height:36px;border:1.5px solid var(--rose);border-radius:50%;position:fixed;pointer-events:none;z-index:9997;transition:all 0.18s ease}

/* PARTICLES */
.ptcl{position:fixed;width:3px;height:3px;background:var(--gold);border-radius:50%;pointer-events:none;z-index:1;opacity:0;animation:pdr 8s linear infinite}
@keyframes pdr{0%{opacity:0;transform:translateY(100vh) scale(0)}10%{opacity:0.8}90%{opacity:0.4}100%{opacity:0;transform:translateY(-20vh) scale(1.5)}}

/* FLOATING NAIL SVGs */
.fnail{position:absolute;z-index:2;pointer-events:none;opacity:0.6}
.fnail svg{filter:drop-shadow(0 4px 16px rgba(212,149,106,0.4))}
@keyframes floatA{0%,100%{transform:translate(0,0) rotate(0deg)}25%{transform:translate(30px,-20px) rotate(8deg)}50%{transform:translate(-10px,-40px) rotate(-5deg)}75%{transform:translate(-30px,-15px) rotate(12deg)}}
@keyframes floatB{0%,100%{transform:translate(0,0) rotate(0deg)}33%{transform:translate(-25px,20px) rotate(-10deg)}66%{transform:translate(20px,-30px) rotate(8deg)}}

/* NAV */
nav{position:fixed;top:0;width:100%;z-index:500;padding:0.8rem 3rem;display:flex;justify-content:space-between;align-items:center;background:rgba(26,10,20,0.92);backdrop-filter:blur(16px);border-bottom:1px solid rgba(212,149,106,0.1)}
nav img{height:45px}
.nl{display:flex;gap:2rem;list-style:none}
.nl a{text-decoration:none;color:var(--muted);font-size:0.75rem;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;transition:color 0.3s}
.nl a:hover{color:var(--rose)}

/* HERO */
#hero{min-height:100vh;position:relative;display:flex;align-items:center;overflow:hidden}
.hvid{position:absolute;inset:0;z-index:0}
.hvid video{width:100%;height:100%;object-fit:cover}
.hover{position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,10,20,0.88),rgba(61,15,32,0.72));z-index:1}
.hcon{position:relative;z-index:3;padding:8rem 3rem 3rem;display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:center;max-width:1400px;margin:0 auto;width:100%}
.hbadge{display:inline-flex;align-items:center;gap:8px;background:rgba(212,149,106,0.15);border:1px solid rgba(212,149,106,0.3);border-radius:50px;padding:0.5rem 1.2rem;font-size:0.7rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--gold);margin-bottom:1.5rem}
h1{font-family:'Playfair Display',serif;font-size:clamp(2.8rem,5vw,5rem);line-height:1.05;font-weight:800;margin-bottom:1rem}
h1 em{font-style:italic;background:linear-gradient(135deg,var(--rose),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;display:block}
.hsub{font-size:1rem;color:var(--muted);line-height:1.85;max-width:440px;margin-bottom:1rem;font-weight:300}
.hprice{display:inline-flex;align-items:center;gap:8px;font-family:'Playfair Display',serif;font-size:1.8rem;color:var(--gold);margin-bottom:2rem}
.hprice small{font-size:0.75rem;color:var(--muted);font-family:'DM Sans',sans-serif;text-transform:uppercase;letter-spacing:0.1em}
.hbtns{display:flex;gap:1rem;flex-wrap:wrap}
.bg{padding:1rem 2.4rem;background:linear-gradient(135deg,var(--rose),var(--deep));color:#fff;border:none;border-radius:50px;font-size:0.85rem;font-weight:500;letter-spacing:0.08em;cursor:pointer;text-decoration:none;transition:all 0.3s;box-shadow:0 0 30px rgba(212,149,106,0.3);display:inline-block}
.bg:hover{transform:translateY(-3px);box-shadow:0 0 50px rgba(212,149,106,0.5)}
.bgl{padding:1rem 2.4rem;background:rgba(255,255,255,0.05);color:var(--gold);border:1px solid rgba(212,149,106,0.3);border-radius:50px;font-size:0.85rem;font-weight:500;letter-spacing:0.08em;cursor:pointer;text-decoration:none;transition:all 0.3s;backdrop-filter:blur(8px);display:inline-block}
.bgl:hover{background:rgba(212,149,106,0.15);transform:translateY(-3px)}
.hiw{position:relative;display:flex;justify-content:center}
.hiw img{width:100%;max-width:500px;border-radius:32px;box-shadow:0 30px 80px rgba(0,0,0,0.5)}
.hglow{position:absolute;width:350px;height:350px;background:radial-gradient(circle,rgba(212,149,106,0.25),transparent 70%);border-radius:50%;top:50%;left:50%;transform:translate(-50%,-50%);animation:gp 4s ease-in-out infinite;z-index:-1}
@keyframes gp{0%,100%{transform:translate(-50%,-50%) scale(1);opacity:0.6}50%{transform:translate(-50%,-50%) scale(1.2);opacity:1}}

/* TICKER */
.ticker{background:linear-gradient(90deg,var(--burg),var(--bg2),var(--burg));padding:0.9rem 0;overflow:hidden;border-top:1px solid rgba(212,149,106,0.1);border-bottom:1px solid rgba(212,149,106,0.1)}
.ti{display:inline-flex;animation:ts 25s linear infinite}
.ti span{padding:0 1.5rem;font-size:0.7rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--muted);white-space:nowrap}
.td{color:var(--rose)!important}
@keyframes ts{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* TRUST */
#trust{padding:3rem;background:var(--bg)}
.trow{display:flex;justify-content:center;gap:3rem;flex-wrap:wrap;max-width:1200px;margin:0 auto}
.tit{display:flex;align-items:center;gap:10px;color:var(--gold);font-size:0.78rem;letter-spacing:0.1em;text-transform:uppercase;font-weight:500}
.tic{width:40px;height:40px;border-radius:12px;background:rgba(212,149,106,0.1);border:1px solid rgba(212,149,106,0.2);display:flex;align-items:center;justify-content:center;font-size:1.2rem}

/* SECTIONS */
.sec{padding:6rem 3rem;position:relative}
.sd{background:var(--bg)}.sd2{background:var(--bg2)}.sb{background:var(--burg)}
.sh{text-align:center;margin-bottom:3.5rem}
.se{font-size:0.7rem;letter-spacing:0.25em;text-transform:uppercase;color:var(--rose);margin-bottom:0.6rem}
.st{font-family:'Playfair Display',serif;font-size:clamp(2rem,3.5vw,3rem);font-weight:700;line-height:1.2}
.st em{background:linear-gradient(135deg,var(--rose),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;font-style:italic}
.ss{color:var(--muted);font-size:0.9rem;margin-top:0.6rem;font-weight:300}
.mw{max-width:1200px;margin:0 auto}

/* GLASS */
.gl{background:rgba(60,25,40,0.4);backdrop-filter:blur(16px);border:1px solid rgba(212,149,106,0.12);border-radius:24px;overflow:hidden;transition:all 0.4s cubic-bezier(.22,.61,.36,1)}
.gl:hover{transform:translateY(-8px);box-shadow:0 20px 60px rgba(212,149,106,0.15);border-color:rgba(212,149,106,0.3)}

/* ABOUT */
.agrid{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center}
.aimgs{position:relative;height:500px}
.ai1{position:absolute;top:0;left:0;width:65%;height:75%;border-radius:24px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,0.3)}
.ai1 img,.ai2 img{width:100%;height:100%;object-fit:cover}
.ai2{position:absolute;bottom:0;right:0;width:50%;height:55%;border-radius:24px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,0.3);border:3px solid rgba(212,149,106,0.2)}
.afl{position:absolute;top:50%;left:55%;transform:translate(-50%,-50%);background:linear-gradient(135deg,var(--rose),var(--deep));color:#fff;border-radius:20px;padding:1.2rem 1.6rem;text-align:center;animation:fb 4s ease-in-out infinite;box-shadow:0 12px 40px rgba(212,149,106,0.3)}
@keyframes fb{0%,100%{transform:translate(-50%,-50%) translateY(0)}50%{transform:translate(-50%,-50%) translateY(-10px)}}
.afl .n{font-family:'Playfair Display',serif;font-size:1.8rem;font-weight:700}
.afl .t{font-size:0.6rem;text-transform:uppercase;letter-spacing:0.12em;opacity:0.85}
.abody{color:var(--muted);line-height:1.9;font-size:0.92rem;font-weight:300;margin-bottom:1.5rem}
.tags{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:2rem}
.tag{padding:0.4rem 1rem;background:rgba(212,149,106,0.1);color:var(--rose);border-radius:50px;font-size:0.72rem;font-weight:500;border:1px solid rgba(212,149,106,0.2);transition:all 0.25s;cursor:default}
.tag:hover{background:var(--rose);color:#fff}

/* SERVICES */
.sgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.5rem}
.scard{padding:2rem;cursor:pointer}
.scard .ico{width:56px;height:56px;border-radius:16px;background:linear-gradient(135deg,rgba(212,149,106,0.2),rgba(212,149,106,0.05));display:flex;align-items:center;justify-content:center;font-size:1.6rem;margin-bottom:1.2rem}
.scard .nm{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;margin-bottom:0.5rem}
.scard .ds{font-size:0.82rem;color:var(--muted);line-height:1.7;font-weight:300}
.scard .pr{margin-top:1rem;color:var(--gold);font-weight:600;font-size:0.9rem}
.scard .vb{margin-top:1rem;color:var(--rose);font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase;font-weight:500;opacity:0;transition:opacity 0.3s}
.scard:hover .vb{opacity:1}

/* EXT BANNER */
.extb{border-radius:28px;overflow:hidden}
.extb img{width:100%;display:block}

/* STEPS */
.steps{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem}
.step{text-align:center;padding:2rem}
.snum{font-family:'Playfair Display',serif;font-size:3rem;font-weight:800;background:linear-gradient(135deg,var(--rose),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;line-height:1}
.stit{font-family:'Playfair Display',serif;font-size:1.1rem;margin:1rem 0 0.5rem;font-weight:600}
.sdsc{font-size:0.82rem;color:var(--muted);font-weight:300;line-height:1.7}

/* PRICING */
.phero{text-align:center;padding:3rem;border-radius:28px;background:linear-gradient(135deg,rgba(212,149,106,0.1),rgba(139,58,74,0.1));border:1px solid rgba(212,149,106,0.15)}
.pbig{font-family:'Playfair Display',serif;font-size:clamp(3rem,6vw,5rem);font-weight:800;background:linear-gradient(135deg,var(--rose),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent}

/* OFFERS */
.ogrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.5rem}
.ocard{padding:2rem;text-align:center;cursor:pointer}
.ocard .oi{font-size:2.5rem;margin-bottom:1rem}
.ocard .ot{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:700;margin-bottom:0.5rem}
.ocard .od{font-size:0.82rem;color:var(--muted);line-height:1.7;font-weight:300}
.ocard .oc{margin-top:1rem;display:inline-block;padding:0.6rem 1.5rem;background:linear-gradient(135deg,var(--rose),var(--deep));color:#fff;border-radius:50px;font-size:0.75rem;text-decoration:none;font-weight:500}

/* TIMER */
.twrap{display:flex;justify-content:center;gap:1.5rem;margin-top:2rem}
.tbox{text-align:center}
.tnum{font-family:'Playfair Display',serif;font-size:2.5rem;font-weight:700;background:linear-gradient(135deg,var(--gold),var(--rose));-webkit-background-clip:text;-webkit-text-fill-color:transparent;line-height:1}
.tlab{font-size:0.6rem;text-transform:uppercase;letter-spacing:0.15em;color:var(--muted);margin-top:4px}

/* GALLERY */
.gstrip{display:flex;gap:1rem;animation:gsc 30s linear infinite;width:max-content}
.gstrip:hover{animation-play-state:paused}
@keyframes gsc{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.gi{width:200px;height:260px;border-radius:20px;flex-shrink:0;overflow:hidden;cursor:pointer;transition:transform 0.3s;position:relative}
.gi:hover{transform:scale(1.06)}
.gi img{width:100%;height:100%;object-fit:cover}
.glab{position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,rgba(0,0,0,0.8));color:#fff;font-size:0.68rem;padding:1rem 0.75rem 0.75rem;text-align:center;font-weight:500;letter-spacing:0.1em;text-transform:uppercase}
.gclr{display:flex;align-items:center;justify-content:center}

/* STUDIO */
.stgrid{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center}
.pal{display:flex;flex-wrap:wrap;gap:10px;margin-top:1.5rem}
.sw{width:40px;height:40px;border-radius:50%;cursor:pointer;border:3px solid transparent;transition:all 0.25s;box-shadow:0 2px 8px rgba(0,0,0,0.3)}
.sw:hover{transform:scale(1.2)}
.sw.on{border-color:var(--gold);transform:scale(1.15)}
#clabel{margin-top:1rem;font-family:'Playfair Display',serif;font-size:1.1rem;color:var(--gold);font-style:italic}
.hwrap{display:flex;justify-content:center}
.hinner{position:relative;animation:hflt 4s ease-in-out infinite}
@keyframes hflt{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}
.hinner canvas{border-radius:24px;box-shadow:0 30px 80px rgba(212,149,106,0.25);display:block}

/* REVIEWS */
.rrow{display:flex;gap:1.5rem;overflow-x:auto;padding-bottom:1rem;scrollbar-width:none}
.rrow::-webkit-scrollbar{display:none}
.rcard{min-width:300px;padding:2rem}
.rstar{color:var(--gold);font-size:0.9rem;margin-bottom:0.8rem;letter-spacing:2px}
.rtxt{font-size:0.88rem;color:var(--muted);line-height:1.8;font-style:italic;font-weight:300;margin-bottom:1rem}
.rnm{font-weight:600;font-size:0.85rem;color:var(--rose)}

/* BRIDAL */
.bgrid{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center}
.bvid{border-radius:28px;overflow:hidden;box-shadow:0 30px 80px rgba(0,0,0,0.4)}
.bvid video{width:100%;display:block}
.bfi{display:flex;align-items:center;gap:10px;color:var(--muted);font-size:0.88rem;margin-bottom:10px}
.bfd{width:8px;height:8px;border-radius:50%;background:var(--gold);flex-shrink:0}

/* FAQ */
.flist{max-width:800px;margin:0 auto}
.fitem{border-bottom:1px solid rgba(212,149,106,0.1)}
.fq{padding:1.2rem 0;cursor:pointer;display:flex;justify-content:space-between;align-items:center;font-weight:500;font-size:0.95rem;transition:color 0.3s}
.fq:hover{color:var(--rose)}
.fq .plus{font-size:1.4rem;color:var(--rose);transition:transform 0.3s}
.fq.open .plus{transform:rotate(45deg)}
.fa{max-height:0;overflow:hidden;transition:max-height 0.4s ease;color:var(--muted);font-size:0.85rem;line-height:1.8;font-weight:300}
.fa.open{max-height:200px;padding-bottom:1rem}

/* CONTACT */
.ccards{display:flex;justify-content:center;gap:1.5rem;flex-wrap:wrap;margin-bottom:3rem}
.cc{padding:1.5rem 2rem;text-align:center;min-width:160px}
.ccic{font-size:1.6rem;margin-bottom:0.6rem}
.cclb{font-size:0.6rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--rose);margin-bottom:0.3rem}
.ccv{font-size:0.82rem}
.wab{display:inline-flex;align-items:center;gap:10px;padding:1.1rem 2.8rem;background:#25D366;color:#fff;border:none;border-radius:50px;font-size:1rem;font-weight:600;cursor:pointer;text-decoration:none;box-shadow:0 0 40px rgba(37,211,102,0.3);transition:all 0.3s}
.wab:hover{transform:translateY(-4px);box-shadow:0 0 60px rgba(37,211,102,0.5)}

/* STICKY WA */
.swa{position:fixed;bottom:24px;right:24px;z-index:900;width:56px;height:56px;background:#25D366;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(37,211,102,0.4);cursor:pointer;text-decoration:none;transition:transform 0.3s;animation:waf 2s ease-in-out infinite}
.swa:hover{transform:scale(1.1)}
@keyframes waf{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}
.swa svg{width:28px;height:28px;fill:#fff}

/* POPUP */
.pov{position:fixed;inset:0;background:rgba(10,5,8,0.85);backdrop-filter:blur(8px);z-index:1000;display:none;align-items:center;justify-content:center;padding:2rem}
.pov.show{display:flex}
.pop{background:var(--bg2);border:1px solid rgba(212,149,106,0.15);border-radius:28px;max-width:500px;width:100%;max-height:85vh;overflow-y:auto;padding:2.5rem;position:relative;animation:popin 0.3s ease}
@keyframes popin{from{opacity:0;transform:scale(0.9) translateY(20px)}to{opacity:1;transform:scale(1) translateY(0)}}
.pcl{position:absolute;top:16px;right:16px;width:36px;height:36px;border-radius:50%;background:rgba(212,149,106,0.1);border:1px solid rgba(212,149,106,0.2);display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--rose);font-size:1.2rem;transition:all 0.2s}
.pcl:hover{background:var(--rose);color:#fff}
.pop h3{font-family:'Playfair Display',serif;font-size:1.5rem;margin-bottom:0.5rem}
.pop .pd{color:var(--muted);font-size:0.88rem;line-height:1.8;font-weight:300;margin:1rem 0}
.pop .pf{list-style:none;margin:1rem 0}
.pop .pf li{padding:0.4rem 0;color:var(--muted);font-size:0.85rem;display:flex;align-items:center;gap:8px}
.pop .pf li::before{content:'✦';color:var(--gold);font-size:0.7rem}

/* FOOTER */
footer{background:#0A0408;padding:3rem;text-align:center;border-top:1px solid rgba(212,149,106,0.08)}
footer img{height:60px;margin-bottom:1rem;opacity:0.7}
footer p{color:rgba(255,240,245,0.3);font-size:0.72rem;letter-spacing:0.08em}
footer span{color:var(--rose)}

/* REVEAL */
.rv{opacity:0;transform:translateY(40px);transition:opacity 0.8s ease,transform 0.8s ease}
.rv.on{opacity:1;transform:translateY(0)}

@media(max-width:768px){
  nav{padding:0.8rem 1.5rem}
  .nl{display:none}
  .hcon,.agrid,.stgrid,.bgrid{grid-template-columns:1fr}
  .hcon{padding:7rem 1.5rem 2rem}
  .hiw{order:-1}
  .sec{padding:4rem 1.5rem}
  .aimgs{height:350px}
  .steps{grid-template-columns:1fr}
  .fnail{display:none}
}
</style>
</head>
<body>

<div id="loader"><img src="images/logo.jpg" alt="Srini's Nailora"><div class="lbar"><div class="lfill"></div></div></div>
<div class="cur" id="cur"></div>
<div class="crg" id="crg"></div>
<div id="ptcls"></div>

<nav>
  <img src="images/logo.jpg" alt="Srini's Nailora">
  <ul class="nl">
    <li><a href="#about">About</a></li>
    <li><a href="#services">Services</a></li>
    <li><a href="#extensions">Extensions</a></li>
    <li><a href="#offers">Offers</a></li>
    <li><a href="#studio">Try On</a></li>
    <li><a href="#contact">Book Now</a></li>
  </ul>
</nav>

<!-- HERO -->
<section id="hero">
  <div class="hvid"><video autoplay muted loop playsinline><source src="videos/hero.mp4" type="video/mp4"></video></div>
  <div class="hover"></div>
  <!-- FLOATING NAILS -->
  <div class="fnail" style="top:15%;left:8%;animation:floatA 12s ease-in-out infinite"><svg width="50" height="80" viewBox="0 0 50 80"><path d="M10 35 Q10 5 25 2 Q40 5 40 35 L40 78 Q25 82 10 78Z" fill="#E8C99A" opacity="0.7"/><ellipse cx="25" cy="18" rx="8" ry="5" fill="rgba(255,255,255,0.3)"/></svg></div>
  <div class="fnail" style="top:60%;left:5%;animation:floatB 15s ease-in-out infinite 1s"><svg width="40" height="65" viewBox="0 0 50 80"><path d="M10 35 Q10 5 25 2 Q40 5 40 35 L40 78 Q25 82 10 78Z" fill="#F4B8C8" opacity="0.6"/><ellipse cx="25" cy="18" rx="8" ry="5" fill="rgba(255,255,255,0.3)"/></svg></div>
